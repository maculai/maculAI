<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Products — Macul.ai</title>
  <meta name="description" content="A connected suite built around how eye practices actually work." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,200;0,300;0,400;1,200;1,300;1,400&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    /* Product row — alternating layout */
    .product-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(40px, 6vw, 96px);
      align-items: center;
    }
    .product-row.reverse .product-text { order: 2; }
    .product-row.reverse .product-visual { order: 1; }
    @media (max-width: 850px) {
      .product-row,
      .product-row.reverse {
        grid-template-columns: 1fr;
      }
      .product-row.reverse .product-text,
      .product-row.reverse .product-visual { order: unset; }
    }

    .product-num {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.3em;
      color: var(--accent);
      margin-bottom: 12px;
      display: block;
    }

    .product-features {
      list-style: none;
      margin-top: 28px;
      display: grid;
      gap: 10px;
    }
    .product-features li {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--text-soft);
      padding-left: 22px;
      position: relative;
    }
    .product-features li::before {
      content: '◎';
      position: absolute;
      left: 0;
      top: 0;
      color: var(--accent);
      font-size: 11px;
    }

    /* Product visual — abstract representation */
    .product-visual {
      position: relative;
      aspect-ratio: 1 / 0.85;
      border: 1px solid var(--border-soft);
      border-radius: 8px;
      overflow: hidden;
      background:
        radial-gradient(ellipse at 30% 20%, rgba(74,240,196,0.06) 0%, transparent 60%),
        linear-gradient(180deg, rgba(6,13,17,0.6), rgba(2,4,8,0.9));
    }
    .product-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(74,240,196,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(74,240,196,0.04) 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    }
    .product-visual-inner {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Visual 1 — charting grid */
    .viz-chart {
      width: 70%;
      height: 60%;
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 14px;
      background: rgba(3, 4, 10, 0.6);
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 10px;
    }
    .viz-chart .row {
      height: 10px;
      background: rgba(74, 240, 196, 0.08);
      border-radius: 2px;
      position: relative;
    }
    .viz-chart .row.accent {
      background: rgba(74, 240, 196, 0.3);
      width: 60%;
    }
    .viz-chart .stack {
      display: grid;
      gap: 6px;
      align-content: start;
    }
    .viz-chart .chip {
      height: 8px;
      border-radius: 2px;
      background: rgba(200,230,220,0.1);
    }
    .viz-chart .chip.a { width: 80%; background: rgba(74, 240, 196, 0.25); }
    .viz-chart .chip.b { width: 55%; }
    .viz-chart .chip.c { width: 72%; }
    .viz-chart .chip.d { width: 40%; background: rgba(74, 240, 196, 0.15); }

    /* Visual 2 — diagnostic eye */
    .viz-iris {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      position: relative;
      background: radial-gradient(circle at 50% 50%,
        #010204 0%,
        #010204 28%,
        rgba(10,38,28,0.6) 40%,
        rgba(18,55,42,0.7) 50%,
        rgba(10,38,28,0.4) 70%,
        rgba(2,7,5,0.1) 90%);
      box-shadow: 0 0 40px rgba(74,240,196,0.1);
    }
    .viz-iris::before {
      content: '';
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      border: 1px solid rgba(74,240,196,0.25);
    }
    .viz-iris::after {
      content: '';
      position: absolute;
      inset: 8%;
      border-radius: 50%;
      border: 1px dashed rgba(74,240,196,0.2);
      animation: spin 32s linear infinite;
    }
    .viz-crosshair {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .viz-crosshair .line {
      position: absolute;
      background: rgba(74, 240, 196, 0.35);
    }
    .viz-crosshair .h {
      top: 50%;
      left: 10%;
      right: 10%;
      height: 1px;
    }
    .viz-crosshair .v {
      left: 50%;
      top: 10%;
      bottom: 10%;
      width: 1px;
    }
    .viz-dot {
      position: absolute;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 10px var(--accent);
    }
    .viz-label {
      position: absolute;
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      padding: 4px 8px;
      border: 1px solid var(--border);
      background: rgba(3, 4, 10, 0.85);
      border-radius: 3px;
    }

    /* Visual 3 — integration nodes */
    .viz-nodes {
      width: 80%;
      height: 80%;
      position: relative;
    }
    .node {
      position: absolute;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: rgba(3, 4, 10, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.14em;
    }
    .node.center {
      width: 80px;
      height: 80px;
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 0 20px rgba(74, 240, 196, 0.2);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 2;
    }
    .node.n1 { top: 8%; left: 20%; }
    .node.n2 { top: 8%; right: 20%; }
    .node.n3 { bottom: 8%; left: 20%; }
    .node.n4 { bottom: 8%; right: 20%; }
    .viz-link {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 1px;
      height: 100px;
      transform-origin: top center;
      background: linear-gradient(180deg, rgba(74,240,196,0.4), transparent);
    }
    .viz-link.l1 { transform: translate(-50%, 0) rotate(45deg); }
    .viz-link.l2 { transform: translate(-50%, 0) rotate(135deg); }
    .viz-link.l3 { transform: translate(-50%, 0) rotate(225deg); }
    .viz-link.l4 { transform: translate(-50%, 0) rotate(315deg); }

    /* Feature strip */
    .feature-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
      background: var(--border-soft);
      border: 1px solid var(--border-soft);
      border-radius: 6px;
      overflow: hidden;
    }
    .feature-strip .cell {
      padding: 32px 24px;
      background: rgba(3, 4, 10, 0.8);
    }
    .feature-strip h4 { margin-bottom: 10px; }
    .feature-strip p { font-size: 12px; }
    @media (max-width: 900px) { .feature-strip { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 500px) { .feature-strip { grid-template-columns: 1fr; } }
  </style>
</head>
